# ─── Server ─────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=7d

# ─── WhatsApp Business API (optional) ───────────────
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_WEBHOOK_VERIFY_TOKEN=

# ─── Database ────────────────────────────────────────
# Default: local NeDB flat files under /data
# Set this to switch to a remote path
DB_PATH=./data
